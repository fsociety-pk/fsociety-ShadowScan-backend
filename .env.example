# ============================================================================
# SHADOW-SCAN ENVIRONMENT CONFIGURATION
# ============================================================================

# Database Configuration
# Local MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27018/shadow_scan_db?authSource=admin
# OR Cloud MongoDB:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/shadow_scan_db

# ============================================================================
# OSINT API KEYS - Email Lookup
# ============================================================================
# Hunter.io - Email verification & corporate data enrichment
# https://hunter.io
HUNTER_API_KEY=your_hunter_api_key_here

# RocketReach - Professional profiles & social discovery
# https://rocketreach.co
ROCKETREACH_API_KEY=your_rocketreach_api_key_here

# Clearbit - Identity enrichment (person & company data)
# https://clearbit.com
CLEARBIT_API_KEY=your_clearbit_api_key_here

# FullContact - Identity & social profile enrichment
# https://fullcontact.com
FULLCONTACT_API_KEY=your_fullcontact_api_key_here

# Have I Been Pwned (HIBP) - Breach database lookups
# https://haveibeenpwned.com/api
HIBP_API_KEY=your_hibp_api_key_here

# ============================================================================
# OSINT API KEYS - Network & IP Intelligence
# ============================================================================
# Shodan - Internet of Things device database
# https://shodan.io
SHODAN_API_KEY=your_shodan_api_key_here

# VirusTotal - URL/IP/Domain threat intelligence
# https://virustotal.com
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB - Malicious IP tracking
# https://abuseipdb.com
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Censys - Internet-wide scan database
# https://censys.io
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# ============================================================================
# OSINT API KEYS - Other Services
# ============================================================================
# Twilio - Phone number intelligence
# https://twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Pastebin - Data leak searching
# https://pastebin.com
PASTEBIN_API_KEY=your_pastebin_api_key_here

# ============================================================================
# AI & LLM APIs
# ============================================================================
# Google Gemini - FREE AI for report generation
# https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (Optional) - GPT-4 for advanced report generation
# https://openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================================
# Server Configuration
# ============================================================================
# Port for backend server
PORT=5000

# Environment: development, production
NODE_ENV=development

# Frontend URL for CORS (single origin)
FRONTEND_URL=http://localhost:5173

# Optional: Comma-separated frontend origins for production
# Example:
# FRONTEND_URLS=https://your-frontend.vercel.app,https://your-custom-domain.com
FRONTEND_URLS=

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret for authentication (minimum 32 chars, use 64+ random chars in production)
# Generate: openssl rand -base64 64
JWT_SECRET=replace_with_generated_jwt_secret

# Admin credentials (initial setup only)
ADMIN_EMAIL=admin@shadow-scan.local
ADMIN_PASSWORD=Admin@2026

FRONTEND_URL=
# Comma-separated list of allowed frontend origins for CORS (preferred)
# Example: FRONTEND_ORIGINS="https://shadowscan.me,https://shadowscan.duckdns.org,http://localhost:5173"
FRONTEND_ORIGINS=
# Generate: openssl rand -base64 64
ADMIN_PANEL_SECRET=replace_with_generated_admin_panel_secret
